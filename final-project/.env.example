# ── Database ─────────────────────────────────────────────
# Main application database. Inside Docker, use the service name "postgres"
# as the host. Outside Docker (running locally), use "localhost".
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/backend_db

# Separate database used ONLY by the automated test suite. Tests freely
# create and drop tables here. Never point this at real data.
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/test_db

# ── Secrets ──────────────────────────────────────────────
# Signs JWT tokens. Must be at least 32 bytes (64 hex characters) -
# shorter keys trigger an InsecureKeyLengthWarning. Generate one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# Never commit a real secret to version control.
SECRET_KEY=change-this-to-a-long-random-string

# ── Redis (caching + background job queue) ─────────────────
# Inside Docker: redis://redis:6379/0
# Outside Docker: redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/0

# ── MongoDB (denormalized activity feed) ────────────────────
# Inside Docker: mongodb://mongo:27017
# Outside Docker: mongodb://localhost:27017
MONGODB_URL=mongodb://localhost:27017
DB_NAME=backend_db

# ── Environment ──────────────────────────────────────────
# "development" enables verbose GraphQL error details (stack traces).
# "production" hides them from API responses - set this before any real deploy.
ENVIRONMENT=development

# ── CORS ─────────────────────────────────────────────────
# Comma-separated list of origins allowed to call this API from a browser.
# Add your frontend's actual URL here (e.g. http://localhost:3000 for a
# local React/Vue dev server). Without this, browsers silently block
# requests from any origin not listed here.
CORS_ORIGINS=http://localhost:3000